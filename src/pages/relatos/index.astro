---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';
import { getCollection } from 'astro:content';

const relatos = await getCollection('relatos', ({ data }) => !data.draft);

function parseDate(dateStr) {
  const parts = dateStr.split(/[\/-]/);
  if (parts.length !== 3) return '0000-00-00';
  let [d, m, y] = parts;
  if (y.length === 2) y = '20' + y;
  return `${y}-${m.padStart(2, '0')}-${d.padStart(2, '0')}`;
}

const sorted = relatos.sort((a, b) => {
  return parseDate(b.data.date).localeCompare(parseDate(a.data.date));
});
---

<BaseLayout title="Relatos" description="Todos los relatos y ensayos de Dr. Digett">
  <div class="page-container">
    <h1 class="hero" style="padding: 20px 0; text-align: left; font-family: var(--font-heading); font-size: 2rem; color: var(--color-primary);">Relatos</h1>
    <div class="story-grid">
      {sorted.map((entry) => (
        <StoryCard
          title={entry.data.title}
          date={entry.data.date}
          slug={entry.slug}
          image={entry.data.image}
          description={entry.data.description}
        />
      ))}
    </div>
  </div>
</BaseLayout>
